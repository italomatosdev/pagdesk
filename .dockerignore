# =============================================================================
# DOCKERIGNORE - PagDesk
# Arquivos e pastas ignorados durante o build da imagem Docker
# =============================================================================

# -----------------------------------------------------------------------------
# Dependências (serão instaladas no build)
# -----------------------------------------------------------------------------
/vendor
/node_modules

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# Ambiente e configurações locais
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.production.example

# -----------------------------------------------------------------------------
# Docker (evita recursão)
# -----------------------------------------------------------------------------
docker-compose*.yml
Dockerfile*
.docker
.dockerignore

# -----------------------------------------------------------------------------
# IDE e editores
# -----------------------------------------------------------------------------
.idea
.vscode
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Logs e cache
# -----------------------------------------------------------------------------
/storage/logs/*
!/storage/logs/.gitignore
/storage/framework/cache/*
!/storage/framework/cache/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore
/bootstrap/cache/*
!/bootstrap/cache/.gitignore

# -----------------------------------------------------------------------------
# Testes
# -----------------------------------------------------------------------------
/tests
phpunit.xml
.phpunit.result.cache
.phpunit.cache
coverage

# -----------------------------------------------------------------------------
# Documentação
# -----------------------------------------------------------------------------
/docs
*.md
!README.md
LICENSE

# -----------------------------------------------------------------------------
# CI/CD
# -----------------------------------------------------------------------------
.github
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# -----------------------------------------------------------------------------
# Outros
# -----------------------------------------------------------------------------
/template-webadmin
/storage/app/public/*
!/storage/app/public/.gitignore
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
