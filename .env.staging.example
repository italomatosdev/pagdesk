# =============================================================================
# VARIÁVEIS DE AMBIENTE - HOMOLOGAÇÃO (STAGING)
# PagDesk
# 
# Copie este arquivo para .env no servidor de staging
# =============================================================================

# Nome do projeto Docker
COMPOSE_PROJECT_NAME=pagdesk-staging

# -----------------------------------------------------------------------------
# APLICAÇÃO
# -----------------------------------------------------------------------------
APP_NAME=PagDesk
APP_ENV=staging
APP_KEY=
APP_DEBUG=true
APP_URL=https://staging.pagdesk.com.br
APP_LOCALE=pt_BR
APP_TIMEZONE=America/Sao_Paulo

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# BANCO DE DADOS (MySQL de Staging - EXTERNO)
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=10.0.0.30
DB_PORT=3306
DB_DATABASE=pagdesk_staging
DB_USERNAME=pagdesk_staging
DB_PASSWORD=

# -----------------------------------------------------------------------------
# DRIVERS
# -----------------------------------------------------------------------------
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=phpredis
CACHE_PREFIX=pagdesk_staging_
REDIS_PREFIX=pagdesk_staging_

# -----------------------------------------------------------------------------
# E-MAIL (Staging pode usar Mailpit ou serviço real)
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="staging@pagdesk.com.br"
MAIL_FROM_NAME="${APP_NAME} Staging"

# -----------------------------------------------------------------------------
# PORTAS DOCKER
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# -----------------------------------------------------------------------------
# GRAFANA (Usar senha diferente de admin)
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_URL=https://grafana-staging.pagdesk.com.br

# -----------------------------------------------------------------------------
# PROMETHEUS
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
