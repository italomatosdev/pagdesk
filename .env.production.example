# =============================================================================
# VARIÁVEIS DE AMBIENTE - PRODUÇÃO
# PagDesk - Laravel Application
# =============================================================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env no servidor
# 2. Preencha TODOS os valores marcados com [OBRIGATÓRIO]
# 3. Gere uma APP_KEY nova: php artisan key:generate
# 4. NUNCA commite o arquivo .env no repositório
# 5. Use senhas fortes (mínimo 16 caracteres, alfanumérico + especiais)
# 6. NUNCA use admin/admin, 123456, ou senhas fracas
#
# SEGURANÇA:
# - Este arquivo NUNCA deve ir para o repositório git
# - Armazene senhas em gerenciador de senhas seguro
# - Rotacione credenciais periodicamente
#
# =============================================================================

# Nome do projeto Docker
COMPOSE_PROJECT_NAME=pagdesk

# -----------------------------------------------------------------------------
# APLICAÇÃO
# -----------------------------------------------------------------------------
APP_NAME="PagDesk"
APP_ENV=production
APP_KEY=                              # [OBRIGATÓRIO] Gerar com: php artisan key:generate
APP_DEBUG=false
APP_URL=https://seu-dominio.com       # [OBRIGATÓRIO] URL da aplicação

# Timezone
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR

# -----------------------------------------------------------------------------
# BANCO DE DADOS (MySQL externo ao Docker)
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=                              # [OBRIGATÓRIO] IP do servidor MySQL
DB_PORT=3306
DB_DATABASE=pagdesk              # [OBRIGATÓRIO] Nome do banco
DB_USERNAME=                          # [OBRIGATÓRIO] Usuário do banco
DB_PASSWORD=                          # [OBRIGATÓRIO] Senha do banco
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# -----------------------------------------------------------------------------
# REDIS (interno ao Docker)
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# -----------------------------------------------------------------------------
# DRIVERS (usando Redis)
# -----------------------------------------------------------------------------
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Prefixos para evitar colisão
CACHE_PREFIX=pagdesk_cache
REDIS_PREFIX=pagdesk_

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# -----------------------------------------------------------------------------
# E-MAIL (configurar conforme seu provedor)
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=                            # Ex: smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@seu-dominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# FILESYSTEM
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local

# S3 (opcional, para armazenamento em nuvem)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------------------------------------
# BROADCAST / PUSHER (opcional)
# -----------------------------------------------------------------------------
BROADCAST_DRIVER=log
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_HOST=
# PUSHER_PORT=443
# PUSHER_SCHEME=https
# PUSHER_APP_CLUSTER=mt1

# -----------------------------------------------------------------------------
# DOCKER / REGISTRY
# -----------------------------------------------------------------------------
REGISTRY_IMAGE=ghcr.io/seu-usuario/pagdesk
IMAGE_TAG=latest

# Portas (padrão)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# -----------------------------------------------------------------------------
# MONITORAMENTO (Grafana)
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=               # [OBRIGATÓRIO] Senha segura para Grafana
GRAFANA_ROOT_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# SEGURANÇA
# -----------------------------------------------------------------------------
# Habilitar HTTPS (quando configurado)
# FORCE_HTTPS=true
# SECURE_COOKIES=true

# CORS (se necessário)
# CORS_ALLOWED_ORIGINS=https://seu-dominio.com

# Rate limiting
# RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
# FILAS
# -----------------------------------------------------------------------------
QUEUE_RETRY_AFTER=90

# Horizon (se usar)
# HORIZON_PREFIX=pagdesk_horizon_

# -----------------------------------------------------------------------------
# OUTROS
# -----------------------------------------------------------------------------
# Sentry (monitoramento de erros)
# SENTRY_LARAVEL_DSN=

# Debugbar (NUNCA habilitar em produção)
DEBUGBAR_ENABLED=false
